# ── Core ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@localhost:5432/rec0ded88
PORT=5000
# development locally; set to production only on the deployed host
NODE_ENV=development

# ── Sessions ───────────────────────────────────────────────────────
# Canonical signing key — required. All admin/player HMAC cookies + JWTs
# fall back to this if a dedicated secret isn't set.
SESSION_SECRET=replace_with_strong_random_secret
# Optional dedicated secrets (recommended in prod to split trust domains)
# ADMIN_SESSION_SECRET=
# PLAYER_SESSION_SECRET=
# Used to sign the short-lived cross-domain launch token (popup handoff).
JWT_SECRET=replace_with_strong_random_jwt_secret
# Optional: share the session cookie across every grudge-studio.com subdomain.
# Defaults to .grudge-studio.com when NODE_ENV=production.
# PLAYER_COOKIE_DOMAIN=.grudge-studio.com

# ── Admin ──────────────────────────────────────────────────────────
ADMIN_PASSCODE=replace_with_strong_admin_passcode

# ── CORS + Embeddable modal allowlist ──────────────────────────────
# Hosts allowed to call /api/* with credentials.
CORS_ORIGINS=https://grudgeplatform.io,https://www.grudgeplatform.io,https://grudgewarlords.com,https://grudge-studio.com,http://localhost:5173
# Hosts allowed to open /auth/popup and receive launch JWTs via postMessage.
# Falls back to CORS_ORIGINS when not set.
AUTH_ALLOWED_ORIGINS=https://grudgeplatform.io,https://www.grudgeplatform.io,https://grudgewarlords.com,https://grudge-studio.com

# ── Discord ───────────────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://grudge-studio.com/api/auth/discord/callback
# Chat/score announcement webhook (separate from OAuth)
DISCORD_ENGINE_WEBHOOK_URL=

# ── GitHub ────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://grudge-studio.com/api/auth/github/callback

# ── Twilio (phone OTP via Verify service) ─────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=

# ── Frontend build-time (only VITE_WS_URL is actually read today) ──
VITE_WS_URL=wss://ws.grudge-studio.com
